# =============================================================================
# SmartPoultry API — Environment Variables
# =============================================================================
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
#
#   cp backend/.env.example backend/.env
#
# On Railway, set these as service variables — DATABASE_URL is injected
# automatically when you link a Postgres service.
# =============================================================================

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# Runtime environment: development | production
# In development, tables are auto-created on startup (Base.metadata.create_all).
# In production, use Alembic migrations or init_db.py instead.
ENVIRONMENT=development

# Human-readable name shown in API docs and responses
PROJECT_NAME=SmartPoultry API

# Semantic version string
VERSION=1.0.0

# API route prefix (all endpoints are mounted under this path)
API_V1_STR=/api/v1

# -----------------------------------------------------------------------------
# Database
# -----------------------------------------------------------------------------

# Full PostgreSQL connection string.
# Railway injects this automatically when a Postgres service is linked.
# For local development use the standard postgresql:// scheme — the app
# will convert it to postgresql+asyncpg:// and strip query parameters.
#
# Examples:
#   Local:   postgresql://postgres:password@localhost:5432/smartpoultry
#   Railway: postgresql://postgres:<password>@<host>:<port>/railway
DATABASE_URL=postgresql://postgres:password@localhost:5432/smartpoultry

# -----------------------------------------------------------------------------
# Security — JWT
# -----------------------------------------------------------------------------

# Secret key used to sign JWT access tokens.
# Generate a strong random value:
#   python3 -c "import secrets; print(secrets.token_hex(64))"
# REQUIRED — the application will not start without this.
SECRET_KEY=change-me-generate-a-strong-random-secret-key-at-least-64-chars

# JWT signing algorithm (HS256 is the default; RS256 requires a key pair)
ALGORITHM=HS256

# Access token lifetime in minutes (default: 60 minutes = 1 hour)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------

# Comma-separated list of allowed frontend origins.
# The app always allows localhost:3000, localhost:3001, and localhost:8000.
# Add your production frontend URL here.
#
# Example:
#   ALLOWED_ORIGINS=https://app.smartpoultry.com,https://www.smartpoultry.com
ALLOWED_ORIGINS=

# -----------------------------------------------------------------------------
# File uploads
# -----------------------------------------------------------------------------

# Directory where uploaded files (profile pictures, production images) are stored.
# Must be writable by the application process.
# On Railway, use /tmp/uploads (ephemeral) or mount a persistent volume.
UPLOAD_DIR=/tmp/uploads

# -----------------------------------------------------------------------------
# Email / SMTP  (optional — password-reset and welcome emails)
# -----------------------------------------------------------------------------

# If any of these are blank, email sending is disabled and reset links are
# printed to stdout instead (useful for development).

# SMTP server hostname
SMTP_HOST=smtp.gmail.com

# SMTP port (587 = STARTTLS, 465 = SSL/TLS, 25 = plain)
SMTP_PORT=587

# SMTP authentication credentials
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# "From" address shown in outgoing emails
EMAIL_FROM=noreply@smartpoultry.com

# Base URL of the frontend — used to build password-reset links
# Example: https://app.smartpoultry.com
FRONTEND_URL=http://localhost:3000

# -----------------------------------------------------------------------------
# Stripe  (optional — subscription payments)
# -----------------------------------------------------------------------------

# Stripe secret key (sk_live_... for production, sk_test_... for testing)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secret (from the Stripe dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret_here

# Price IDs from your Stripe product catalogue
STRIPE_BASIC_PRICE_ID=price_basic_plan_id
STRIPE_PRO_PRICE_ID=price_professional_plan_id

# -----------------------------------------------------------------------------
# Google OAuth  (optional — "Sign in with Google")
# -----------------------------------------------------------------------------

# OAuth 2.0 client credentials from Google Cloud Console
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
